<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- 图书管理系统数据库连接字符串 -->
		<!-- 修改说明：
         1. Data Source：替换为你本地的SQL Server实例名（必填！）
            - 常见实例名：.\\SQLEXPRESS（本地Express版）、(local)（本地默认实例）、电脑名\\SQLEXPRESS
         2. Initial Catalog：替换为你还原后的数据库名称（必填！）
            - 示例：若还原的数据库名是BookMS，就填BookMS
         3. Integrated Security=True：使用Windows身份验证（无需改，不用输账号密码）
         4. MultipleActiveResultSets=True：支持多结果集（无需改）-->
		<add key="BookMS_Conn" value="Data Source=KOMOREBI\SQLEXPRESS;Initial Catalog=BookMS;Integrated Security=True;MultipleActiveResultSets=True"/>
	</appSettings>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
	</startup>
</configuration>